<view class="dish-card" bindtap="onCardTap">
  <view class="card-image-wrapper">
    <image 
      class="card-image" 
      src="{{dish.images[0]}}" 
      mode="aspectFill"
      lazy-load="{{true}}"
    />
    <view class="favorite-btn" catchtap="onFavoriteTap">
      <text class="heart-icon {{isFavorite ? 'active' : ''}}">{{isFavorite ? '❤️' : '🤍'}}</text>
    </view>
  </view>
  
  <view class="card-content">
    <text class="dish-name">{{dish.name}}</text>
    
    <view class="dish-meta">
      <view class="category-tag">{{dish.category}}</view>
      <view class="rating">
        <text class="star">⭐</text>
        <text class="rating-value">{{dish.rating.toFixed(1)}}</text>
      </view>
    </view>
    
    <view class="author-info">
      <image class="author-avatar" src="{{dish.authorAvatar}}" mode="aspectFill" />
      <text class="author-name">{{dish.authorName}}</text>
    </view>
  </view>
</view>
