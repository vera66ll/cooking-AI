<view class="login-page">
  <!-- 顶部品牌区域 -->
  <view class="hero-section">
    <view class="logo-wrap">
      <text class="logo-icon">🍜</text>
    </view>
    <text class="app-name">美食记</text>
    <text class="app-slogan">记录每一道美味</text>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 手机号输入框 -->
    <view class="input-group">
      <view class="input-row {{phoneError ? 'input-error' : ''}}">
        <text class="input-icon">📱</text>
        <input
          class="input-field"
          type="number"
          placeholder="请输入手机号"
          placeholder-class="input-placeholder"
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
          bindfocus="onPhoneFocus"
          bindblur="onPhoneBlur"
        />
        <text class="clear-btn" wx:if="{{phone}}" catchtap="clearPhone">×</text>
      </view>
      <text class="error-tip" wx:if="{{phoneError}}">{{phoneError}}</text>
    </view>

    <!-- 密码输入框 -->
    <view class="input-group">
      <view class="input-row {{passwordError ? 'input-error' : ''}}">
        <text class="input-icon">🔒</text>
        <input
          class="input-field"
          password="{{!showPassword}}"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          bindfocus="onPasswordFocus"
          bindblur="onPasswordBlur"
        />
        <text class="toggle-pwd" catchtap="togglePassword">{{showPassword ? '🙈' : '👁️'}}</text>
      </view>
      <text class="error-tip" wx:if="{{passwordError}}">{{passwordError}}</text>
    </view>

    <!-- 记住我 + 忘记密码 -->
    <view class="options-row">
      <view class="remember-me" catchtap="toggleRemember">
        <view class="checkbox {{rememberMe ? 'checked' : ''}}">
          <text class="check-mark" wx:if="{{rememberMe}}">✓</text>
        </view>
        <text class="remember-text">记住我</text>
      </view>
      <text class="forgot-pwd" catchtap="onForgotPassword">忘记密码？</text>
    </view>

    <!-- 登录按钮 -->
    <button
      class="login-btn {{isLoading ? 'loading' : ''}}"
      bindtap="onLogin"
      disabled="{{isLoading}}"
    >
      <text wx:if="{{!isLoading}}">登 录</text>
      <view wx:else class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </button>

    <!-- 分割线 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或者</text>
      <view class="divider-line"></view>
    </view>

    <!-- 微信一键登录 -->
    <button
      class="wechat-btn {{isWxLoading ? 'loading' : ''}}"
      bindtap="onWechatLogin"
      disabled="{{isWxLoading}}"
    >
      <text class="wechat-icon">💬</text>
      <text wx:if="{{!isWxLoading}}">微信一键登录</text>
      <text wx:else>登录中...</text>
    </button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link">用户协议</text>
    <text class="footer-text">和</text>
    <text class="footer-link">隐私政策</text>
  </view>
</view>
