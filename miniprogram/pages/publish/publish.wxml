<view class="publish-page">
  <scroll-view class="form-container" scroll-y enhanced>
    <!-- 图片上传 -->
    <view class="form-section">
      <text class="section-title">菜品图片</text>
      <image-upload 
        images="{{images}}"
        maxCount="{{9}}"
        bind:change="onImagesChange"
      />
    </view>

    <!-- 菜品名称 -->
    <view class="form-section">
      <text class="section-title">菜品名称</text>
      <input 
        class="form-input" 
        placeholder="请输入菜品名称"
        value="{{formData.name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 菜系选择 -->
    <view class="form-section">
      <text class="section-title">菜系分类</text>
      <picker 
        mode="selector" 
        range="{{categories}}"
        value="{{categoryIndex}}"
        bindchange="onCategoryChange"
      >
        <view class="picker-value">
          {{categoryIndex >= 0 ? categories[categoryIndex] : '请选择菜系'}}
        </view>
      </picker>
    </view>

    <!-- 菜品描述 -->
    <view class="form-section">
      <text class="section-title">菜品描述/做法</text>
      <textarea 
        class="form-textarea"
        placeholder="请输入菜品描述和详细做法..."
        value="{{formData.description}}"
        bindinput="onDescriptionInput"
        maxlength="-1"
      />
    </view>

    <!-- 标签 -->
    <view class="form-section">
      <text class="section-title">标签（可选）</text>
      <view class="tag-input-wrapper">
        <block wx:for="{{tags}}" wx:key="index">
          <view class="tag-item">
            <text>{{item}}</text>
            <text class="tag-delete" catchtap="onDeleteTag" data-index="{{index}}">×</text>
          </view>
        </block>
        <input 
          class="tag-input"
          placeholder="输入标签后按回车"
          value="{{tagInput}}"
          bindinput="onTagInput"
          bindconfirm="onAddTag"
        />
      </view>
    </view>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="publish-btn-wrapper">
    <button class="publish-btn" bindtap="onPublish">发布</button>
  </view>
</view>
